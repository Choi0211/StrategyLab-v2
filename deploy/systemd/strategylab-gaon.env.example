GAON_RUNTIME_MODE=execute
GAON_DRY_RUN=false
GAON_TELEGRAM_ENABLED=true
GAON_TELEGRAM_BOT_TOKEN=<set-private-token-outside-git>
GAON_TELEGRAM_ALLOWED_CHAT_IDS=<comma-separated-allowed-chat-ids>
GAON_APPROVAL_SIGNING_SECRET=<set-private-approval-secret-outside-git>
GAON_ASSISTANT_ENABLED=false
GAON_ASSISTANT_PROVIDER=deterministic
GAON_ASSISTANT_API_KEY=
GAON_ASSISTANT_BASE_URL=
GAON_ASSISTANT_MODEL=
GAON_ASSISTANT_TIMEOUT_SECONDS=10
GAON_ASSISTANT_MAX_OUTPUT_TOKENS=2048
GAON_ASSISTANT_MAX_CONTINUATIONS=2
