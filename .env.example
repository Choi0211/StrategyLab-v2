# StrategyLab v2 example environment.
# Do not put real broker keys, account IDs, or notification tokens in this file.

STRATEGYLAB_ENV=development
STRATEGYLAB_CONFIG=config/config.example.yaml

# Gaon Runtime dry-run defaults.
# Leave token values empty unless explicitly configuring a local dry-run/execute environment.
# Do not commit a real .env file or real Telegram token.
GAON_RUNTIME_MODE=dry-run
GAON_TELEGRAM_ENABLED=false
GAON_TELEGRAM_BOT_TOKEN=
GAON_TELEGRAM_ALLOWED_CHAT_IDS=
GAON_NOTION_ENABLED=false
GAON_NOTION_TOKEN=
GAON_NOTION_PARENT_PAGE_ID=
GAON_NOTION_RESEARCH_DATABASE_ID=
GAON_NOTION_MEMORY_DATABASE_ID=
GAON_ASSISTANT_ENABLED=false
GAON_ASSISTANT_PROVIDER=deterministic
GAON_ASSISTANT_API_KEY=
GAON_ASSISTANT_BASE_URL=
GAON_ASSISTANT_MODEL=
GAON_ASSISTANT_TIMEOUT_SECONDS=10
GAON_ASSISTANT_MAX_OUTPUT_TOKENS=500
GAON_TIMEZONE=Asia/Seoul
GAON_DAILY_REPORT_TIME=09:00
GAON_WEEKLY_REPORT_DAY=MONDAY
GAON_WEEKLY_REPORT_TIME=09:00
GAON_DRY_RUN=true
